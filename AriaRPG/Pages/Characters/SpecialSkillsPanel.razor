@inject AriaService AriaService

<div class="fade-in">
    <div class="aria-card">
        <div class="aria-card-header">
            <h4><i class="bi bi-stars"></i> Compétences Spéciales (@SpecialSkills.Count)</h4>
            <button class="btn-aria btn-aria-sm" @onclick="AddSkill">
                <i class="bi bi-plus-lg"></i> Ajouter
            </button>
        </div>

        @if (SpecialSkills.Count == 0)
        {
            <p style="color: var(--aria-text-muted); text-align: center; padding: 2rem;">
                <i class="bi bi-stars" style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></i>
                Aucune compétence spéciale. Cliquez sur Ajouter pour commencer.
            </p>
        }
        else
        {
            <div class="skill-list">
                @foreach (var skill in SpecialSkills)
                {
                    var scoreClass = skill.Value >= 40 ? "skill-high" : skill.Value >= 25 ? "skill-mid" : "skill-low";

                    <div class="skill-row">
                        <div class="skill-row-top">
                            <input class="skill-name-input" @bind="skill.Name" placeholder="Nom..." />
                            <div class="skill-bonus-controls">
                                <button class="btn-bonus" @onclick="() => { skill.Value -= 1; }">-1</button>
                                <input type="number" @bind="skill.Value"
                                       class="special-skill-score-input @scoreClass" />
                                <button class="btn-bonus btn-bonus-plus" @onclick="() => { skill.Value += 1; }">+1</button>
                            </div>
                        </div>
                        <div class="skill-row-bottom">
                            <div class="skill-meta" style="flex: 1; gap: 0.5rem;">
                                <input class="skill-inline-input" @bind="skill.Type" placeholder="Type..." />
                                <input class="skill-inline-input" @bind="skill.Description" placeholder="Description..." style="flex: 2;" />
                            </div>
                            <div style="display: flex; gap: 0.3rem; flex-shrink: 0;">
                                <button class="btn-aria-success" @onclick="() => SaveSkill(skill)">
                                    <i class="bi bi-check"></i>
                                </button>
                                <button class="btn-aria-danger" @onclick="() => DeleteSkill(skill.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int CharacterId { get; set; }
    [Parameter] public List<CharacterSpecialSkill> SpecialSkills { get; set; } = new();
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task AddSkill()
    {
        var skill = new CharacterSpecialSkill
        {
            CharacterId = CharacterId,
            Name = "Nouvelle compétence spéciale",
            Value = 0
        };
        await AriaService.AddSpecialSkillAsync(skill);
        await OnChanged.InvokeAsync();
    }

    private async Task SaveSkill(CharacterSpecialSkill skill)
    {
        await AriaService.UpdateSpecialSkillAsync(skill);
        await OnChanged.InvokeAsync();
    }

    private async Task DeleteSkill(int id)
    {
        await AriaService.DeleteSpecialSkillAsync(id);
        await OnChanged.InvokeAsync();
    }
}